          const fileReader = new FileReader();
          fileReader.onload = function (e) {
            applyAndCacheMediaHQData(e.target.result);
          };
          fileReader.readAsDataURL(selectedFile);
        } else if (urlString) {
          applyAndCacheMediaHQData(urlString);
        } else {
          uiDisplayCenterDialog(
            "LỖI THAO TÁC",
            "Đồng chí vui lòng điền link liên kết URL hoặc chọn tệp tin hình ảnh từ bộ nhớ máy.",
