      // --- SPREADSHEET EXCEL INTEGRATION ENGINE (XỬ LÝ FILE EXCEL CHUYÊN SÂU) ---
      function helperFormatExcelSheet(worksheet, dataMatrix) {
        // Hàm phụ cấu hình căn giữa và độ rộng thích hợp cho các cột không bị mất chữ
        const colWidths = [];
        dataMatrix.forEach((row) => {
          row.forEach((cell, i) => {
            const cellVal =
              cell !== null && cell !== undefined ? cell.toString() : "";
            if (!colWidths[i] || cellVal.length > colWidths[i]) {
              colWidths[i] = cellVal.length;
            }
          });
        });
        worksheet["!cols"] = colWidths.map((w) => ({
          wch: Math.max(w + 5, 12),
        }));

        // Duyệt tất cả ô để định dạng cân bằng ở giữa, in đậm dòng đầu
        for (let cellId in worksheet) {
          if (cellId[0] === "!") continue;
          if (!worksheet[cellId].s) worksheet[cellId].s = {};

          worksheet[cellId].s.alignment = {
            horizontal: "center",
            vertical: "center",
            wrapText: true,
          };

          // Kiểm tra xem có phải dòng tiêu đề số 1 không để thiết lập In Đậm
          const rowNum = parseInt(cellId.replace(/[^0-9]/g, ""));
          if (rowNum === 1) {
            worksheet[cellId].s.font = {
              bold: true,
              name: "Arial",
              sz: 11,
            };
          }
        }
      }

      function actionExportSingleDayExcel() {
        const dateString =
          document.getElementById("ctrlAttendanceDate").value ||
          "Chưa_Xác_Định_Ngày";
        const workbookDataMatrix = [
          [
            "STT",
            "Họ và Tên Đoàn Viên",
            "Năm Sinh",
            `Trạng thái điểm danh ngày ${dateString}`,
          ],
        ];

        globalActiveMembers.forEach((member) => {
          const checkedBox = document.querySelector(
            `input[data-owner-stt="${member.stt}"][data-status-type]:checked`,
          );
          const currentStatus = checkedBox
            ? checkedBox.getAttribute("data-status-type")
            : "";
          workbookDataMatrix.push([
            member.stt,
            member.name,
            member.yob,
            currentStatus,
          ]);
        });

        const workbook = XLSX.utils.book_new();
        const worksheet = XLSX.utils.aoa_to_sheet(workbookDataMatrix);
        helperFormatExcelSheet(worksheet, workbookDataMatrix);
        XLSX.utils.book_append_sheet(workbook, worksheet, "NhatKyDiemDanh");
        XLSX.writeFile(workbook, `DiemDanh_ChiDoan_TienHoa_${dateString}.xlsx`);
      }

      function actionExportComprehensiveReport() {
        let masterHistoryObj = JSON.parse(
          localStorage.getItem("th_v3_master_history_vault") || "{}",
        );
        let recordDates = Object.keys(masterHistoryObj).sort();

        let topHeaderRow = ["STT", "Họ và Tên Đoàn Viên", "Năm Sinh"];
        recordDates.forEach((date) => topHeaderRow.push(`Ngày ${date}`));
        topHeaderRow.push(
          "Tổng Buổi Tham Gia (X)",
          "Nghỉ Có Phép (P)",
          "Nghỉ Không Phép (K)",
        );

        let spreadsheetDataMatrix = [topHeaderRow];

        globalActiveMembers.forEach((member, indexOffset) => {
          let dataRow = [member.stt, member.name, member.yob];
          let sumX = 0,
            sumP = 0,
            sumK = 0;

          recordDates.forEach((date) => {
            let dayRecordArray = masterHistoryObj[date];
            if (dayRecordArray && dayRecordArray[indexOffset] !== undefined) {
              let statusSymbol = dayRecordArray[indexOffset];
              dataRow.push(statusSymbol);
              if (statusSymbol === "X") sumX++;
              if (statusSymbol === "P") sumP++;
              if (statusSymbol === "K") sumK++;
            } else {
              dataRow.push("");
            }
          });

          dataRow.push(sumX, sumP, sumK);
          spreadsheetDataMatrix.push(dataRow);
        });

        const workbook = XLSX.utils.book_new();
        const worksheet = XLSX.utils.aoa_to_sheet(spreadsheetDataMatrix);
        helperFormatExcelSheet(worksheet, spreadsheetDataMatrix);
        XLSX.utils.book_append_sheet(workbook, worksheet, "BaoCaoTongHop");
        XLSX.writeFile(
          workbook,
          `Bao_Cao_Tong_Hop_So_Hoa_Chi_Doan_Tien_Hoa.xlsx`,
        );
      }

      // VÙNG SỬA ĐỔI: TỰ ĐỘNG ĐỒNG BỘ LÊN EXCEL KHÔNG CẦN CHỌN TỆP (CÓ HIỆU ỨNG CHỜ LOANH QUANH 2 GIÂY CHUYÊN NGHIỆP)
      function actionDirectSyncExcelReport() {
        const activeDateInputStr =
          document.getElementById("ctrlAttendanceDate").value || "Chưa rõ ngày";

        // Hiện thông báo đang đồng bộ xử lý (Có vòng tròn xoay spinner chuyên nghiệp)
        uiDisplayCenterDialog(
          "",
          "",
          true,
          `<h3>HỆ THỐNG ĐANG XỬ LÝ ĐỒNG BỘ</h3>
           <div style="line-height:1.6; color: var(--text-secondary); font-size:0.95rem; margin-bottom:24px; display:flex; flex-direction:column; align-items:center; gap:16px;">
              <i class="fa-solid fa-spinner fa-spin" style="font-size: 2.2rem; color: var(--color-primary);"></i>
              <p>Đang đồng bộ...</p>
           </div>`,
        );

        // Giả lập tiến trình đồng bộ dữ liệu thông minh đúng 2 giây (2000ms)
        setTimeout(() => {
          let masterHistoryObj = JSON.parse(
            localStorage.getItem("th_v3_master_history_vault") || "{}",
          );
          let recordDates = Object.keys(masterHistoryObj).sort();

          if (!recordDates.includes(activeDateInputStr)) {
            recordDates.push(activeDateInputStr);
          }

          let topHeaderRow = ["STT", "Họ và Tên Đoàn Viên", "Năm Sinh"];
          recordDates.forEach((date) => topHeaderRow.push(`Ngày ${date}`));
          topHeaderRow.push("Tham Gia (X)", "Có Phép (P)", "Không Phép (K)");

          let parsedDataMatrix = [topHeaderRow];

          globalActiveMembers.forEach((member, indexOffset) => {
            let dataRow = [member.stt, member.name, member.yob];
            let sumX = 0,
              sumP = 0,
              sumK = 0;

            recordDates.forEach((date) => {
              let dayRecordArray = masterHistoryObj[date];
              let statusSymbol = "";

              if (date === activeDateInputStr) {
                const checkedBox = document.querySelector(
                  `input[data-owner-stt="${member.stt}"][data-status-type]:checked`,
                );
                statusSymbol = checkedBox
                  ? checkedBox.getAttribute("data-status-type")
                  : "";
              } else if (
                dayRecordArray &&
                dayRecordArray[indexOffset] !== undefined
              ) {
                statusSymbol = dayRecordArray[indexOffset];
              }

              dataRow.push(statusSymbol);
              if (statusSymbol === "X") sumX++;
              if (statusSymbol === "P") sumP++;
              if (statusSymbol === "K") sumK++;
            });

            dataRow.push(sumX, sumP, sumK);
            parsedDataMatrix.push(dataRow);
          });

          const newWorkbook = XLSX.utils.book_new();
          const newWorksheet = XLSX.utils.aoa_to_sheet(parsedDataMatrix);

          // Thực thi căn bằng ở giữa ô, co giãn độ rộng cột và in đậm tiêu đề
          helperFormatExcelSheet(newWorksheet, parsedDataMatrix);

          XLSX.utils.book_append_sheet(
            newWorkbook,
            newWorksheet,
            "DongBoTichHop",
          );
          XLSX.writeFile(
            newWorkbook,
            `DiemDanh_TienHoa_DongBo_TichHop_${activeDateInputStr}.xlsx`,
          );

          // Tắt màn hình chờ và hiển thị thông báo thành công
          uiCloseCenterDialog();
          uiDisplayCenterDialog(
            "ĐỒNG BỘ THÀNH CÔNG",
            `Dữ liệu điểm danh ngày <b>${activeDateInputStr}</b> đã được tự động đồng bộ hóa lên tệp Excel hoàn tất! Toàn bộ các ô chữ đã tự động cân bằng vào giữa và căn chỉnh độ rộng cột chuẩn xác.`,
          );
        }, 2000);
      }

      // --- THEME ENGINE: ĐIỀU PHỐI GIAO DIỆN SÁNG / TỐI ---
      function triggerToggleTheme() {
        const rootElement = document.documentElement;
        if (rootElement.getAttribute("data-theme") === "dark") {
          rootElement.setAttribute("data-theme", "light");
        } else {
          rootElement.setAttribute("data-theme", "dark");
        }
      }
    </script>
    
