      // Đặt mặc định ngày hiện tại vào ô Input Lịch họp
      document.getElementById("ctrlAttendanceDate").valueAsDate = new Date();

      // HÀM KHỞI CHẠY CHÍNH KHI TRANG TẢI XONG (INITIALIZATION ENGINE)
      window.addEventListener("DOMContentLoaded", () => {
        // Đồng bộ và tải các thiết lập Media High-Resolution
        const cachedBanner = localStorage.getItem("th_hq_system_banner");
        const cachedLogo = localStorage.getItem("th_hq_system_logo");
        if (cachedBanner)
          document.getElementById("domSystemBanner").style.backgroundImage =
            `url('${cachedBanner}')`;
        if (cachedLogo)
          document.getElementById("domSystemLogo").src = cachedLogo;

        // Khởi tạo và nạp danh sách thực thể đoàn viên
        if (localStorage.getItem("th_master_members_db_v3")) {
          globalActiveMembers = JSON.parse(
            localStorage.getItem("th_master_members_db_v3"),
          );
        } else {
          let trackerYob = 2011;
          globalActiveMembers = coreIdentityDataset.map((rawName, idx) => {
            let cleanName = rawName.trim();
            if (cleanName.includes("Cao Đức Huy")) trackerYob = 2010;
            if (cleanName.includes("Nguyễn Lê Đăng Đán")) trackerYob = 2009;
            if (cleanName.includes("Nguyễn Hoàng Gia Bảo")) trackerYob = 2008;
            return { stt: idx + 1, name: cleanName, yob: trackerYob };
          });
          localStorage.setItem(
            "th_master_members_db_v3",
            JSON.stringify(globalActiveMembers),
          );
        }

        // Hiện Pop-up chào mừng mang tính chuyên nghiệp định hướng an toàn
        uiDisplayCenterDialog(
          "HỆ THỐNG QUẢN LÝ ĐIỂM DANH",
          "Trân trọng chào mừng đồng chí đến với Sổ Điện Tử Điểm Danh Chi Đoàn Tiến Hòa – nền tảng hỗ trợ quản lý, theo dõi và kết nối hoạt động chi đoàn một cách hiệu quả.",
        );

        // Dựng giao diện lõi
        systemBuildMainAttendanceTable();
        statsRenderComprehensiveTable();

        // Đảm bảo block Admin CRUD mở sẵn kiến trúc
        document.getElementById("blockAdminCrudSection").style.display =
          "block";
      });

      // --- ENGINE ĐIỀU HƯỚNG CHUYỂN ĐỔI GIỮA 3 MỤC ĐỘC LẬP ---
      function switchSystemTab(tabName) {
        document
          .getElementById("tabBtnAttendance")
          .classList.remove("tab-state-active");
        document
          .getElementById("tabBtnStats")
          .classList.remove("tab-state-active");
        document
          .getElementById("tabBtnCrud")
          .classList.remove("tab-state-active");

        document
          .getElementById("sectionAttendance")
          .classList.remove("section-state-visible");
        document
          .getElementById("sectionStats")
          .classList.remove("section-state-visible");
        document
          .getElementById("sectionCrud")
          .classList.remove("section-state-visible");

        if (tabName === "attendance") {
          document
            .getElementById("tabBtnAttendance")
            .classList.add("tab-state-active");
          document
            .getElementById("sectionAttendance")
            .classList.add("section-state-visible");
        } else if (tabName === "stats") {
          document
            .getElementById("tabBtnStats")
            .classList.add("tab-state-active");
          document
            .getElementById("sectionStats")
            .classList.add("section-state-visible");
          statsRenderComprehensiveTable();
        } else if (tabName === "crud") {
          document
            .getElementById("tabBtnCrud")
            .classList.add("tab-state-active");
          document
            .getElementById("sectionCrud")
            .classList.add("section-state-visible");
        }
      }

      // --- UI ENGINE: HỘP THOẠI POP-UP DIALOG ĐỘC LẬP TÙY BIẾN CHUYÊN NGHIỆP ---
      function uiDisplayCenterDialog(
        title,
        message,
        isCustomLayout = false,
        customHtml = "",
      ) {
        const overlay = document.getElementById("domGlobalModalOverlay");
        const card = document.getElementById("domGlobalModalCard");

        if (isCustomLayout) {
          card.innerHTML = customHtml;
        } else {
          card.innerHTML = `
                <h3>${title}</h3>
                <div style="line-height:1.6; color: var(--text-secondary); text-size-adjust: 100%; font-size:0.95rem; margin-bottom:24px;">${message}</div>
                <button class="btn-core btn-primary" onclick="uiCloseCenterDialog()" style="width:100%; padding:12px;">Xác Nhận & Đóng</button>
            `;
        }
        overlay.classList.add("overlay-active");
      }

      // Tắt màn hình chờ
      function uiCloseCenterDialog() {
        document
          .getElementById("domGlobalModalOverlay")
          .classList.remove("overlay-active");
      }

      // --- MAIN TABLE ENGINE: KHỞI TẠO VÀ ĐIỀU PHỐI BẢNG ĐIỀU DANH CHÍNH ---
      function systemBuildMainAttendanceTable() {
        const tbody = document.getElementById("domMainTableBody");
        tbody.innerHTML = "";

        document.getElementById("domMetricTotal").innerText =
          globalActiveMembers.length;
        document.getElementById("domMasterRowCheckbox").checked = false;

        globalActiveMembers.forEach((member) => {
          const tr = document.createElement("tr");
          tr.id = `attendance-row-${member.stt}`;
          tr.setAttribute("data-search-key", member.name.toLowerCase());

          tr.innerHTML = `
                <td>
                    <div style="display: inline-flex; align-items: center; gap: 12px;">
                        <input type="checkbox" class="row-individual-selector" data-row-stt="${member.stt}" onchange="tableProcessRowHighlight(this)">
                        <strong>${member.stt}</strong>
                    </div>
                </td>
                <td style="text-align: left; font-weight: 600;">${member.name}</td>
                <td><span style="background-color: rgba(37,99,235,0.08); color: var(--color-primary); padding: 5px 12px; border-radius: 6px; font-weight: 700; font-size: 0.85rem;">${member.yob}</span></td>
                <td>
                    <div class="attendance-checkbox-cluster">
                        <label class="attendance-label-node node-x text-x"><input type="checkbox" data-owner-stt="${member.stt}" data-status-type="X" onchange="tableHandleCheckboxInteraction(this)"> X</label>
                        <label class="attendance-label-node node-p text-p"><input type="checkbox" data-owner-stt="${member.stt}" data-status-type="P" onchange="tableHandleCheckboxInteraction(this)"> P</label>
                        <label class="attendance-label-node node-k text-k"><input type="checkbox" data-owner-stt="${member.stt}" data-status-type="K" onchange="tableHandleCheckboxInteraction(this)"> K</label>
                    </div>
                </td>
            `;
          tbody.appendChild(tr);
        });

        actionLoadDateAttendance();
        crudBuildSyncManagementTable();
        controlToolbarVisibility();
      }

      // XỬ LÝ CLICK ĐỒNG BỘ ĐIỂM DANH - CAM KẾT BAN ĐẦU KHÔNG TÍCH Ô NÀO
      function tableHandleCheckboxInteraction(targetCheckbox) {
        const ownerStt = targetCheckbox.getAttribute("data-owner-stt");
        const statusType = targetCheckbox.getAttribute("data-status-type");

        if (targetCheckbox.checked) {
          document
            .querySelectorAll(
              `input[data-owner-stt="${ownerStt}"][data-status-type]`,
            )
            .forEach((cb) => {
              if (cb.getAttribute("data-status-type") !== statusType) {
                cb.checked = false;
              }
            });
        }

        systemRecalculateLiveMetrics();
        actionSaveDateAttendance();
        statsRenderComprehensiveTable();
      }

      // TÍNH TOÁN SỐ LIỆU ĐIỂM DANH LIVE TRÊN MÀN HÌNH CHÍNH
      function systemRecalculateLiveMetrics() {
        let countX = 0,
          countP = 0,
          countK = 0;
        document
          .querySelectorAll(
            '#domMainTableBody input[type="checkbox"][data-status-type]:checked',
          )
          .forEach((cb) => {
            const type = cb.getAttribute("data-status-type");
            if (type === "X") countX++;
            if (type === "P") countP++;
            if (type === "K") countK++;
          });
        document.getElementById("domMetricX").innerText = countX;
        document.getElementById("domMetricP").innerText = countP;
        document.getElementById("domMetricK").innerText = countK;
      }

      // NÚT CHỌN TẤT CẢ TẠI CỘT STT CHỈ ĐỂ CHỌN HÀNG/BÔI ĐẬM DÒNG (HIGHLIGHT) - ẨN/HIỆN THAO TÁC NHANH
      function tableToggleMasterRowSelect(masterCb) {
        document.querySelectorAll(".row-individual-selector").forEach((cb) => {
          const tr = cb.closest("tr");
          if (tr && tr.style.display !== "none") {
            cb.checked = masterCb.checked;
            if (cb.checked) {
              tr.classList.add("row-state-highlighted");
            } else {
              tr.classList.remove("row-state-highlighted");
            }
          }
        });
        controlToolbarVisibility();
      }

      function tableProcessRowHighlight(individualCb) {
        const tr = individualCb.closest("tr");
        if (!tr) return;
        if (individualCb.checked) {
          tr.classList.add("row-state-highlighted");
        } else {
          tr.classList.remove("row-state-highlighted");
        }
        controlToolbarVisibility();
      }

      // HÀM ĐIỀU KHIỂN ẨN HIỆN CỦA THANH THAO TÁC NHANH DỰA TRÊN Ô TÍCH CHỌN SỐ DÒNG
      function controlToolbarVisibility() {
        if (!stateIsAdminMode) {
          document.getElementById("blockAdminQuickToolbar").style.display =
            "none";
          return;
        }
        const selectedCount = document.querySelectorAll(
          ".row-individual-selector:checked",
        ).length;
        const toolbar = document.getElementById("blockAdminQuickToolbar");

        if (selectedCount > 0) {
          toolbar.style.display = "flex";
        } else {
          toolbar.style.display = "none";
        }
      }

      // LOGIC MỚI: TÍCH ĐỒNG LOẠT 3 PHẦN THAM GIA/PHÉP/KHÔNG PHÉP CHO CÁC DÒNG ĐƯỢC CHỌN
      function toolbarApplyStatusToSelected(statusType) {
        const selectedCheckboxes = document.querySelectorAll(
          ".row-individual-selector:checked",
        );
        if (selectedCheckboxes.length === 0) return;

        selectedCheckboxes.forEach((scb) => {
          const stt = scb.getAttribute("data-row-stt");

          // Tắt tích chọn cũ của dòng này trước
          document
            .querySelectorAll(
              `input[data-owner-stt="${stt}"][data-status-type]`,
            )
            .forEach((cb) => (cb.checked = false));

          // Kích hoạt ô trạng thái được yêu cầu (X, P hoặc K)
          const targetBox = document.querySelector(
            `input[data-owner-stt="${stt}"][data-status-type="${statusType}"]`,
          );
          if (targetBox) targetBox.checked = true;
        });

        systemRecalculateLiveMetrics();
        actionSaveDateAttendance();
        statsRenderComprehensiveTable();
        actionApplyTableFilters();
      }

      // Hủy bỏ chọn dòng nhanh chóng
      function toolbarClearRowSelection() {
        document.getElementById("domMasterRowCheckbox").checked = false;
        document.querySelectorAll(".row-individual-selector").forEach((cb) => {
          cb.checked = false;
          const tr = cb.closest("tr");
          if (tr) tr.classList.remove("row-state-highlighted");
        });
        controlToolbarVisibility();
      }

      // SỬ DỤNG THANH ĐIỀU KHIỂN TÌM KIẾM VÀ LỌC TRẠNG THÁI TRÊN BẢNG CHÍNH
      function actionApplyTableFilters() {
        const queryText = document
          .getElementById("ctrlSearchBox")
          .value.toLowerCase()
          .trim();
        const filterStatus = document.getElementById("ctrlStatusFilter").value;

        globalActiveMembers.forEach((member) => {
          const tr = document.getElementById(`attendance-row-${member.stt}`);
          if (!tr) return;

          const isNameMatched = member.name.toLowerCase().includes(queryText);
          const checkedBox = document.querySelector(
            `input[data-owner-stt="${member.stt}"][data-status-type]:checked`,
          );
          const activeStatus = checkedBox
            ? checkedBox.getAttribute("data-status-type")
            : "EMPTY";

          let isStatusMatched =
            filterStatus === "ALL" || activeStatus === filterStatus;

          if (isNameMatched && isStatusMatched) {
            tr.style.display = "";
          } else {
            tr.style.display = "none";
          }
        });
        toolbarClearRowSelection(); // Reset vùng bôi đen khi tiến hành lọc tránh lỗi hiển thị lệch dòng
      }

      // LƯU TRỮ VÀ KHỞI TẠI DỮ LIỆU ĐIỂM DANH THEO NGÀY VÀO LOCALSTORAGE
      function actionSaveDateAttendance() {
        const targetDateKey =
          document.getElementById("ctrlAttendanceDate").value;
        if (!targetDateKey) return;

        const dateAttendanceStateArr = globalActiveMembers.map((member) => {
          const checked = document.querySelector(
            `input[data-owner-stt="${member.stt}"][data-status-type]:checked`,
          );
          return checked ? checked.getAttribute("data-status-type") : "";
        });

        localStorage.setItem(
          `th_v3_date_state_${targetDateKey}`,
          JSON.stringify(dateAttendanceStateArr),
        );

        let masterHistoryObj = JSON.parse(
          localStorage.getItem("th_v3_master_history_vault") || "{}",
        );
        masterHistoryObj[targetDateKey] = dateAttendanceStateArr;
        localStorage.setItem(
          "th_v3_master_history_vault",
          JSON.stringify(masterHistoryObj),
        );

        statsRenderComprehensiveTable();
      }

      function actionLoadDateAttendance() {
        const targetDateKey =
          document.getElementById("ctrlAttendanceDate").value;
        if (!targetDateKey) return;

        document
          .querySelectorAll('#domMainTableBody input[type="checkbox"]')
          .forEach((cb) => (cb.checked = false));
        document
          .querySelectorAll("#domMainTableBody tr")
          .forEach((tr) => tr.classList.remove("row-state-highlighted"));

        const savedDayJson = localStorage.getItem(
          `th_v3_date_state_${targetDateKey}`,
        );
        if (savedDayJson) {
          const stateArr = JSON.parse(savedDayJson);
          stateArr.forEach((statusType, index) => {
            if (statusType) {
              let targetMember = globalActiveMembers[index];
              if (targetMember) {
                const cb = document.querySelector(
                  `input[data-owner-stt="${targetMember.stt}"][data-status-type="${statusType}"]`,
                );
                if (cb) cb.checked = true;
              }
            }
          });
        }

        systemRecalculateLiveMetrics();
        actionApplyTableFilters();
      }

      // --- CRUD ENGINE: PHÂN HỆ QUẢN LÝ THÊM/SỬA/XÓA TÁCH BIỆT ĐỒNG BỘ TỰ ĐỘNG ---
      function crudBuildSyncManagementTable() {
        const tbody = document.getElementById("domCrudTableBody");
        if (!tbody) return;
        tbody.innerHTML = "";

        globalActiveMembers.forEach((member) => {
          const tr = document.createElement("tr");
          tr.innerHTML = `
                <td><b>${member.stt}</b></td>
                <td style="text-align: left; font-weight: 600;">${member.name}</td>
                <td><span style="font-weight: 700; color: var(--color-primary);">${member.yob}</span></td>
                <td>
                    <button class="btn-core btn-secondary" style="padding: 4px 12px; font-size: 0.8rem;" onclick="crudActionLoadMemberToForm(${member.stt})"><i class="fa-solid fa-user-pen"></i> Sửa</button>
                    <button class="btn-core" style="padding: 4px 12px; font-size: 0.8rem; background-color: #fee2e2; color: #ef4444; border:none;" onclick="crudActionExecuteDeleteMember(${member.stt})"><i class="fa-solid fa-user-xmark"></i> Xóa</button>
                </td>
            `;
          tbody.appendChild(tr);
        });
      }

      function crudActionLoadMemberToForm(stt) {
        const member = globalActiveMembers.find((m) => m.stt === stt);
        if (!member) return;

        document.getElementById("formStateTargetStt").value = member.stt;
        document.getElementById("formInputName").value = member.name;
        document.getElementById("formInputYob").value = member.yob;

        document.getElementById("btnFormSubmitAction").innerHTML =
          '<i class="fa-solid fa-floppy-disk"></i> Cập Nhật Dòng';
        document.getElementById("btnFormSubmitAction").className =
          "btn-core btn-warning";
        document.getElementById("btnFormCancelAction").style.display =
          "inline-flex";

        document.getElementById("formInputName").focus();
      }

      function crudResetFormState() {
        document.getElementById("formStateTargetStt").value = "";
        document.getElementById("formInputName").value = "";
        document.getElementById("formInputYob").value = "2008";

        document.getElementById("btnFormSubmitAction").innerHTML =
          '<i class="fa-solid fa-circle-plus"></i> Thêm Mới';
        document.getElementById("btnFormSubmitAction").className =
          "btn-core btn-primary";
        document.getElementById("btnFormCancelAction").style.display = "none";
      }

      function crudExecuteSaveMember() {
        const nameValue = document.getElementById("formInputName").value.trim();
        const yobValue = parseInt(
          document.getElementById("formInputYob").value,
        );
        const stateSttStr = document.getElementById("formStateTargetStt").value;

        if (!nameValue || !yobValue) {
          uiDisplayCenterDialog(
            "LỖI HOẠT ĐỘNG",
            "Họ tên đoàn viên và năm sinh không được phép để trống.",
          );
          return;
        }

        if (stateSttStr !== "") {
          let targetStt = parseInt(stateSttStr);
          let idx = globalActiveMembers.findIndex((m) => m.stt === targetStt);
          if (idx !== -1) {
            globalActiveMembers[idx].name = nameValue;
            globalActiveMembers[idx].yob = yobValue;
            uiDisplayCenterDialog(
              "THÀNH CÔNG",
              `Đã cập nhật thông tin chỉnh sửa của đoàn viên STT số ${targetStt} thành công trên toàn bộ hệ thống.`,
            );
          }
        } else {
          let maxStt =
            globalActiveMembers.length > 0
              ? Math.max(...globalActiveMembers.map((m) => m.stt)) + 1
              : 1;
          globalActiveMembers.push({
            stt: maxStt,
            name: nameValue,
            yob: yobValue,
          });
          uiDisplayCenterDialog(
            "ĐÃ THÊM MỚI",
            `Đoàn viên mới <b>${nameValue}</b> đã được tạo lập dữ liệu thành công.`,
          );
        }

        localStorage.setItem(
          "th_master_members_db_v3",
          JSON.stringify(globalActiveMembers),
        );
        crudResetFormState();
        systemBuildMainAttendanceTable();
      }

      function crudActionExecuteDeleteMember(stt) {
        let idx = globalActiveMembers.findIndex((m) => m.stt === stt);
        if (idx !== -1) {
          let deletedName = globalActiveMembers[idx].name;
          globalActiveMembers.splice(idx, 1);

          globalActiveMembers.forEach((m, i) => {
            m.stt = i + 1;
          });

          localStorage.setItem(
            "th_master_members_db_v3",
            JSON.stringify(globalActiveMembers),
          );
          crudResetFormState();
          systemBuildMainAttendanceTable();
          uiDisplayCenterDialog(
            "ĐÃ THỰC THI XÓA",
            `Hệ thống đã loại bỏ hoàn toàn đoàn viên <b>${deletedName}</b> ra khỏi danh sách.`,
          );
        }
      }

      function crudExecuteDeleteEntireDateHistory() {
        const currentDateKey =
          document.getElementById("ctrlAttendanceDate").value;
        if (!currentDateKey) return;

        localStorage.removeItem(`th_v3_date_state_${currentDateKey}`);
        let masterHistoryObj = JSON.parse(
          localStorage.getItem("th_v3_master_history_vault") || "{}",
        );
        delete masterHistoryObj[currentDateKey];
        localStorage.setItem(
          "th_v3_master_history_vault",
          JSON.stringify(masterHistoryObj),
        );

        systemBuildMainAttendanceTable();
        uiDisplayCenterDialog(
          "ĐÃ XÓA NHẬT KÝ",
          `Đã xóa sạch toàn bộ cột lịch sử điểm danh của ngày họp ${currentDateKey}.`,
        );
      }

      // --- CHỨC NĂNG MỚI: XÓA VÀ KHÔI PHỤC TOÀN BỘ CƠ SỞ DỮ LIỆU VAULT ---
      function systemClearAllDatabaseVault() {
        let masterHistoryObj = localStorage.getItem(
          "th_v3_master_history_vault",
        );
        let masterMembersObj = localStorage.getItem("th_master_members_db_v3");

        if (masterHistoryObj || masterMembersObj) {
          localStorage.setItem(
            "th_backup_history_vault",
            masterHistoryObj || "{}",
          );
          localStorage.setItem(
            "th_backup_members_db",
            masterMembersObj || "[]",
          );
        }

        localStorage.removeItem("th_v3_master_history_vault");

        // Dọn dẹp các key ngày lẻ
        for (let i = 0; i < localStorage.length; i++) {
          let key = localStorage.key(i);
          if (key && key.startsWith("th_v3_date_state_")) {
            localStorage.removeItem(key);
            i--;
          }
        }

        systemBuildMainAttendanceTable();
        statsRenderComprehensiveTable();
        uiDisplayCenterDialog(
          "ĐÃ XÓA TẤT CẢ DỮ LIỆU",
          "Hệ thống đã xóa sạch toàn bộ lịch sử điểm danh của các ngày trên trình duyệt. Bản sao lưu tạm thời đã được ghi nhận.",
        );
      }

      function systemRestoreAllDatabaseVault() {
        let backupHistory = localStorage.getItem("th_backup_history_vault");
        let backupMembers = localStorage.getItem("th_backup_members_db");

        if (!backupHistory && !backupMembers) {
          uiDisplayCenterDialog(
            "KHÔNG CÓ DỮ LIỆU KHÔI PHỤC",
            "Hệ thống chưa tìm thấy tệp bản ghi sao lưu lịch sử nào trước đó để tiến hành khôi phục.",
          );
          return;
        }

        if (backupHistory) {
          localStorage.setItem("th_v3_master_history_vault", backupHistory);
          let historyObj = JSON.parse(backupHistory);
          Object.keys(historyObj).forEach((dateKey) => {
            localStorage.setItem(
              `th_v3_date_state_${dateKey}`,
              JSON.stringify(historyObj[dateKey]),
            );
          });
        }

        if (backupMembers) {
          localStorage.setItem("th_master_members_db_v3", backupMembers);
          globalActiveMembers = JSON.parse(backupMembers);
        }

        systemBuildMainAttendanceTable();
        statsRenderComprehensiveTable();
        uiDisplayCenterDialog(
          "KHÔI PHỤC THÀNH CÔNG",
          "Hệ thống đã phục hồi thành công toàn bộ dữ liệu lịch sử điểm danh và danh sách đoàn viên từ bộ nhớ sao lưu.",
        );
      }

      // --- STATS ENGINE: BẢNG TRA CỨU THỐNG KÊ LỌC THEO LỊCH CHUYÊN SÂU ---
      // Hàm reset bộ lọc lịch thống kê về chế độ cộng dồn tất cả ngày
      function statsResetToAllDates() {
        document.getElementById("ctrlHistoryStatsDatePicker").value = "";
        statsRenderComprehensiveTable();
      }

      function statsRenderComprehensiveTable() {
        const tbody = document.getElementById("domHistoryStatsTableBody");
        if (!tbody) return;
        tbody.innerHTML = "";

        let masterHistoryObj = JSON.parse(
          localStorage.getItem("th_v3_master_history_vault") || "{}",
        );
        const selectedDate = document.getElementById(
          "ctrlHistoryStatsDatePicker",
        ).value;

        let focusDatesArray = [];
        // Nếu người dùng không chọn ngày nào thì tính cộng dồn toàn bộ lịch sử
        if (!selectedDate) {
          focusDatesArray = Object.keys(masterHistoryObj).sort();
        } else {
          // Ngược lại chỉ lấy đúng ngày được chỉ định trên lịch sử chọn
          if (masterHistoryObj[selectedDate]) {
            focusDatesArray.push(selectedDate);
          }
        }

        if (focusDatesArray.length === 0) {
          tbody.innerHTML = `<tr><td colspan="6" style="color: var(--text-muted); padding: 24px;">Hệ thống chưa ghi nhận bất kỳ dữ liệu lịch sử nào phù hợp với ngày được chọn.</td></tr>`;
          return;
        }

        // Duyệt qua tất cả các ngày được chọn, ngày nào có ít nhất một người có trạng thái (X, P, K) thì tính là 1 buổi tổ chức của chi đoàn
        let totalSessionsOrganized = 0;
        focusDatesArray.forEach((dateKey) => {
          let dayRecordArray = masterHistoryObj[dateKey];
          if (dayRecordArray && dayRecordArray.length > 0) {
            // Kiểm tra xem trong ngày này có ô nào được tích chọn không (khác chuỗi rỗng)
            let hasAnyAttendance = dayRecordArray.some(
              (status) => status !== undefined && status !== "",
            );
            if (hasAnyAttendance) {
              totalSessionsOrganized++;
            }
          }
        });

        globalActiveMembers.forEach((member, indexOffset) => {
          let tallyX = 0,
            tallyP = 0,
            tallyK = 0;

          focusDatesArray.forEach((dateKey) => {
            let dayRecordArray = masterHistoryObj[dateKey];
            if (dayRecordArray && dayRecordArray[indexOffset] !== undefined) {
              let markStatus = dayRecordArray[indexOffset];
              if (markStatus === "X") tallyX++;
              if (markStatus === "P") tallyP++;
              if (markStatus === "K") tallyK++;
            }
          });

          const tr = document.createElement("tr");
          tr.innerHTML = `
                <td>${member.stt}</td>
                <td style="text-align: left; font-weight: 600;">${member.name}</td>
                <td><b style="color: var(--color-success); font-size:1.05rem;">${tallyX}</b></td>
                <td><b style="color: var(--color-warning); font-size:1.05rem;">${tallyP}</b></td>
                <td><b style="color: var(--color-danger); font-size:1.05rem;">${tallyK}</b></td>
                <td><b style="color: var(--color-purple); font-size:1.05rem;">${totalSessionsOrganized}</b></td>
            `;
          tbody.appendChild(tr);
        });
      }

