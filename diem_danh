<html lang="vi" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      Sổ Điện Tử Điểm Danh Chi Đoàn Tiến Hòa - Phiên Bản Đặc Biệt Hoàn Hảo
    </title>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <style>
      /* --- ĐỊNH NGHĨA HỆ THỐNG BIẾN TOÀN CỤC TOÀN DIỆN (THEME VARIABLES) --- */
      :root {
        --bg-base: #f1f5f9;
        --bg-container: rgba(255, 255, 255, 0.85);
        --bg-card: #ffffff;
        --bg-input: #f8fafc;
        --text-primary: #0f172a;
        --text-secondary: #63738a;
        --text-muted: #64748b;
        --border-main: #cbd5e1;
        --border-light: #e2e8f0;
        --color-primary: #2563eb;
        --color-primary-hover: #1d4ed8;
        --color-primary-rgb: 37, 99, 235;
        --color-success: #10b981;
        --color-success-hover: #059669;
        --color-warning: #f59e0b;
        --color-warning-hover: #d97706;
        --color-danger: #ef4444;
        --color-danger-hover: #dc2626;
        --color-purple: #8b5cf6;
        --color-purple-hover: #7c3aed;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow-md:
          0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        --shadow-lg:
          0 10px 15px -3px rgba(0, 0, 0, 0.1),
          0 4px 6px -2px rgba(0, 0, 0, 0.05);
        --shadow-xl:
          0 20px 25px -5px rgba(0, 0, 0, 0.1),
          0 10px 10px -5px rgba(0, 0, 0, 0.04);
        --shadow-glass: 0 8px 32px 0 rgba(31, 38, 135, 0.06);
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 18px;
        --radius-xl: 26px;
        --blur-strength: 16px;
        --transition-fast: 0.15s ease;
        --transition-normal: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      }

      [data-theme="dark"] {
        --bg-base: #020617;
        --bg-container: rgba(15, 23, 42, 0.8);
        --bg-card: #1e293b;
        --bg-input: #0f172a;
        --text-primary: #f8fafc;
        --text-secondary: #cbd5e1;
        --text-muted: #94a3b8;
        --border-main: #475569;
        --border-light: #334155;
        --color-primary: #3b82f6;
        --color-primary-hover: #60a5fa;
        --color-primary-rgb: 59, 130, 246;
        --color-success: #34d399;
        --color-success-hover: #10b981;
        --color-warning: #fbbf24;
        --color-warning-hover: #f59e0b;
        --color-danger: #f87171;
        --color-danger-hover: #ef4444;
        --color-purple: #a78bfa;
        --color-purple-hover: #8b5cf6;
        --shadow-glass: 0 8px 32px 0 rgba(0, 0, 0, 0.4);
      }

      /* --- KIỂU DÁNG MẶC ĐỊNH TOÀN TRANG (BASE RESETS) --- */
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family:
          "Inter",
          system-ui,
          -apple-system,
          sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        background-color: var(--bg-base);
        color: var(--text-primary);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
        transition:
          background-color var(--transition-normal),
          color var(--transition-normal);
      }

      /* --- BANNER PREMIUM ULTRA HD GRAPHICS (Tách biệt 3 dòng rõ ràng) --- */
      .premium-banner-wrapper {
        width: 100%;
        display: flex;
        flex-direction: column;
        box-shadow: var(--shadow-xl);
      }

      /* Hàng 1: Khu vực ảnh bìa thuần túy */
      .premium-banner {
        position: relative;
        width: 100%;
        height: 260px;
        background-image: url("https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&w=1920&q=100");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        transition: background-image var(--transition-normal);
      }

      .premium-banner::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(
          180deg,
          rgba(0, 0, 0, 0.1) 0%,
          rgba(0, 0, 0, 0.4) 100%
        );
        z-index: 1;
      }

      /* Nút đổi giao diện & Đăng nhập nằm gọn góc trên phải của Ảnh bìa */
      .banner-top-right-cluster {
        position: absolute;
        top: 20px;
        right: 20px;
        display: flex;
        gap: 12px;
        z-index: 12;
      }

      /* Nút Thay đổi ảnh nền/logo thu gọn đưa vào góc dưới phải của ảnh bìa */
      .banner-media-controls {
        position: absolute;
        bottom: 20px;
        right: 20px;
        display: none;
        gap: 12px;
        z-index: 10;
      }

      /* Hàng 2: Khung chứa Logo, Tiêu đề chính lớn và Thông tin */
      .banner-identity-row {
        background-color: var(--bg-card);
        border-bottom: 1px solid var(--border-light);
        padding: 24px;
        transition: background-color var(--transition-normal);
      }

      .banner-container {
        width: 100%;
        max-width: 1300px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 24px;
      }

      /* === CHỈNH SỬA LOGO ĐOÀN LỚN HƠN === */
      .logo-wrapper {
        position: relative;
        width: 140px; /* Tăng từ 100px lên 140px */
        height: 140px; /* Tăng từ 100px lên 140px */
        flex-shrink: 0;
      }

      .logo-main {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid var(--border-main); /* Tăng viền dày lên tí nhìn cho chất lượng */
        background-color: #ffffff;
        box-shadow: var(--shadow-lg);
        transition: transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
        cursor: pointer;
      }

      .logo-main:hover {
        transform: rotate(360deg) scale(1.05);
      }

      .banner-text h1 {
        color: var(--text-primary);
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -0.5px;
        text-transform: uppercase;
      }

      .banner-text p {
        color: var(--text-secondary);
        font-size: 1.05rem;
        margin-top: 6px;
        font-weight: 400;
      }

      /* Hàng 3: Thanh trạng thái màu tối hệ thống chuyển xuống dưới cùng */
      .status-header-bar {
        background-color: #0f172a;
        padding: 14px 24px;
        display: flex;
        justify-content: center;
        align-items: center;
      }

      [data-theme="dark"] .status-header-bar {
        background-color: #1e293b;
      }

      .badge-role {
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: var(--shadow-sm);
      }

      /* --- HỆ THỐNG NÚT BẤM (BUTTON ARCHITECTURE) --- */
      .btn-core {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 20px;
        font-size: 0.9rem;
        font-weight: 600;
        border-radius: var(--radius-md);
        border: 1px solid transparent;
        cursor: pointer;
        white-space: nowrap;
        user-select: none;
        transition: all var(--transition-fast);
      }

      .btn-core:active {
        transform: scale(0.97);
      }

      .btn-banner-action {
        background: rgba(15, 23, 42, 0.7);
        color: #ffffff;
        border: 1px solid rgba(255, 255, 255, 0.25);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
      }

      .btn-banner-action:hover {
        background: var(--color-primary);
        border-color: transparent;
        box-shadow: 0 4px 12px rgba(var(--color-primary-rgb), 0.3);
      }

      .btn-banner-danger {
        background: rgba(239, 68, 68, 0.85);
        color: #ffffff;
        border: 1px solid rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
      }

      .btn-banner-danger:hover {
        background: var(--color-danger-hover);
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
      }

      .btn-primary {
        background-color: var(--color-primary);
        color: #ffffff;
      }
      .btn-primary:hover {
        background-color: var(--color-primary-hover);
      }

      .btn-success {
        background-color: var(--color-success);
        color: #ffffff;
      }
      .btn-success:hover {
        background-color: var(--color-success-hover);
      }

      .btn-warning {
        background-color: var(--color-warning);
        color: #ffffff;
      }
      .btn-warning:hover {
        background-color: var(--color-warning-hover);
      }

      .btn-danger {
        background-color: var(--color-danger);
        color: #ffffff;
      }
      .btn-danger:hover {
        background-color: var(--color-danger-hover);
      }

      .btn-purple {
        background-color: var(--color-purple);
        color: #ffffff;
      }
      .btn-purple:hover {
        background-color: var(--color-purple-hover);
      }

      .btn-secondary {
        background-color: var(--bg-card);
        color: var(--text-primary);
        border: 1px solid var(--border-main);
      }
      .btn-secondary:hover {
        background-color: var(--bg-input);
      }

      .btn-disabled-style {
        background-color: #94a3b8 !important;
        color: #cbd5e1 !important;
        cursor: not-allowed !important;
        opacity: 0.65 !important;
        box-shadow: none !important;
        transform: none !important;
      }

      /* --- KHUNG CONTAINER TRUNG TÂM (MAIN APPARATUS) --- */
      .app-container {
        width: 95%;
        max-width: 1300px;
        margin: 40px auto 60px auto;
        position: relative;
        background-color: var(--bg-container);
        backdrop-filter: blur(var(--blur-strength));
        -webkit-backdrop-filter: blur(var(--blur-strength));
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: var(--radius-xl);
        padding: 40px;
        box-shadow: var(--shadow-xl), var(--shadow-glass);
        z-index: 5;
      }

      /* --- HỆ THỐNG MENU TAB PHÂN CHIA 3 MỤC RIÊNG BIỆT --- */
      .navigation-tabs-container {
        display: flex;
        gap: 10px;
        margin-bottom: 25px;
        border-bottom: 2px solid var(--border-light);
        padding-bottom: 10px;
      }

      .tab-trigger-btn {
        padding: 12px 24px;
        font-size: 0.95rem;
        font-weight: 700;
        border-radius: var(--radius-md);
        border: 1px solid var(--border-main);
        background-color: var(--bg-card);
        color: var(--text-secondary);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all var(--transition-fast);
      }

      .tab-trigger-btn:hover {
        background-color: var(--bg-input);
        color: var(--color-primary);
      }

      .tab-trigger-btn.tab-state-active {
        background-color: var(--color-primary);
        color: #ffffff;
        border-color: transparent;
        box-shadow: var(--shadow-md);
      }

      .app-functional-section-view {
        display: none;
      }

      .app-functional-section-view.section-state-visible {
        display: block;
      }

      /* --- BẢNG ĐIỀU KHIỂN & BỘ LỌC (MANAGEMENT DASHBOARD CONTROL) --- */
      .dashboard-control-deck {
        background-color: var(--bg-card);
        border-radius: var(--radius-lg);
        padding: 24px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        align-items: flex-end;
        border: 1px solid var(--border-light);
        margin-bottom: 35px;
        box-shadow: var(--shadow-sm);
      }

      .deck-field {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .deck-field label {
        font-weight: 700;
        font-size: 0.8rem;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .input-premium {
        padding: 12px 16px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border-main);
        background-color: var(--bg-input);
        color: var(--text-primary);
        font-weight: 600;
        font-size: 0.95rem;
        outline: none;
        width: 100%;
        transition:
          border-color var(--transition-fast),
          box-shadow var(--transition-fast);
      }

      .input-premium:focus {
        border-color: var(--color-primary);
        box-shadow: 0 0 0 3px rgba(var(--color-primary-rgb), 0.15);
      }

      .deck-actions-cluster {
        grid-column: 1 / -1;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        border-top: 1px solid var(--border-light);
        padding-top: 18px;
        margin-top: 4px;
      }

      /* --- PHÂN HỆ QUẢN TRỊ VIÊN ĐỘC LẬP TÁCH BIỆT TRỰC QUAN (CRUD SYSTEM) --- */
      .crud-isolated-section {
        background-color: var(--bg-card);
        border: 2px solid var(--color-primary);
        border-radius: var(--radius-lg);
        padding: 30px;
        margin-bottom: 35px;
        box-shadow: var(--shadow-lg);
      }

      .crud-section-title {
        margin-bottom: 20px;
        font-size: 1.25rem;
        color: var(--color-primary);
        font-weight: 800;
        border-bottom: 2px solid var(--border-light);
        padding-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .crud-form-layout {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        background-color: var(--bg-input);
        padding: 20px;
        border-radius: var(--radius-md);
        margin-bottom: 24px;
        border: 1px dashed var(--border-main);
        align-items: flex-end;
      }

      .crud-table-wrapper {
        max-height: 450px;
        overflow-y: auto;
        border-radius: var(--radius-md);
        border: 1px solid var(--border-main);
        box-shadow: var(--shadow-sm);
      }

      /* --- KHỐI THÀNH PHẦN THỐNG KÊ NHANH (METRIC GRID) --- */
      .metric-cards-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 35px;
      }

      .metric-box {
        background-color: var(--bg-card);
        border-radius: var(--radius-lg);
        padding: 24px;
        text-align: center;
        font-weight: 700;
        border: 1px solid var(--border-light);
        box-shadow: var(--shadow-md);
        position: relative;
        overflow: hidden;
      }

      .metric-box::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        width: 6px;
        height: 100%;
      }
      .metric-total::before {
        background-color: var(--color-primary);
      }
      .metric-x::before {
        background-color: var(--color-success);
      }
      .metric-p::before {
        background-color: var(--color-warning);
      }
      .metric-k::before {
        background-color: var(--color-danger);
      }

      .metric-box p {
        margin: 0;
        font-size: 0.85rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.8px;
      }

      .metric-box span {
        display: block;
        font-size: 2.3rem;
        margin-top: 8px;
        font-weight: 800;
        line-height: 1;
      }
      .text-total {
        color: var(--color-primary);
      }
      .text-x {
        color: var(--color-success);
      }
      .text-p {
        color: var(--color-warning);
      }
      .text-k {
        color: var(--color-danger);
      }

      /* --- THANH TÁC VỤ NHANH CHO ADMIN CHỈNH SỬA ẨN/HIỆN THÔNG MINH --- */
      .admin-quick-toolbar {
        display: none; /* Điều khiển hiển thị linh hoạt qua JS */
        justify-content: flex-start;
        align-items: center;
        gap: 14px;
        margin-bottom: 24px;
        background-color: rgba(37, 99, 235, 0.05);
        padding: 16px 24px;
        border-radius: var(--radius-md);
        border: 1px dashed var(--color-primary);
        animation: fadeInToolbar 0.25s ease-in-out;
      }

      @keyframes fadeInToolbar {
        from {
          opacity: 0;
          transform: translateY(-8px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .toolbar-title {
        font-weight: 800;
        font-size: 0.85rem;
        color: var(--color-primary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      /* --- KIẾN TRÚC BẢNG BIỂU SIÊU CẤU TRÚC (DATATABLE SYSTEM) --- */
      .responsive-table-holder {
        overflow-x: auto;
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-main);
        box-shadow: var(--shadow-md);
        margin-bottom: 35px;
        background-color: var(--bg-card);
      }

      .structural-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        text-align: center;
      }

      .structural-table th {
        background-color: var(--color-primary);
        color: #ffffff;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 18px 20px;
        border-bottom: 2px solid rgba(0, 0, 0, 0.05);
      }

      .structural-table td {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border-light);
        color: var(--text-primary);
        font-size: 0.95rem;
        vertical-align: middle;
        transition: background-color var(--transition-fast);
      }

      .structural-table tbody tr:last-child td {
        border-bottom: none;
      }

      .structural-table tbody tr:nth-child(even) {
        background-color: var(--bg-input);
      }

      /* LOGIC ĐIỀU CHỈNH CHỌN DÒNG (HIGHLIGHT ROW) */
      .structural-table tbody tr.row-state-highlighted {
        background-color: rgba(var(--color-primary-rgb), 0.12) !important;
        font-weight: 600;
      }

      .structural-table tbody tr:hover {
        background-color: rgba(var(--color-primary-rgb), 0.03);
      }

      /* Cột tiêu đề chứa hộp kiểm Master Chọn Dòng */
      .master-select-header {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        user-select: none;
      }

      .master-select-header input[type="checkbox"],
      .row-individual-selector {
        width: 18px;
        height: 18px;
        cursor: pointer;
        accent-color: var(--color-primary);
      }

      /* Hộp kiểm lựa chọn điểm danh */
      .attendance-checkbox-cluster {
        display: flex;
        justify-content: center;
        gap: 24px;
      }

      .attendance-label-node {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        font-weight: 700;
        font-size: 1.05rem;
        user-select: none;
      }

      .attendance-label-node input[type="checkbox"] {
        width: 22px;
        height: 22px;
        cursor: pointer;
        border-radius: var(--radius-sm);
      }

      .node-x input {
        accent-color: var(--color-success);
      }
      .node-p input {
        accent-color: var(--color-warning);
      }
      .node-k input {
        accent-color: var(--color-danger);
      }

      /* Trạng thái khóa bảng khi chưa đăng nhập */
      .table-lock-state {
        pointer-events: none;
        opacity: 0.9;
      }

      /* --- TIỆN ÍCH THỐNG KÊ LỌC THEO LỊCH (ADVANCED STATISTICS PANEL) --- */
      .widget-panel-block {
        background-color: var(--bg-card);
        border-radius: var(--radius-lg);
        padding: 32px;
        margin-top: 10px;
        border: 1px solid var(--border-light);
        border-left: 6px solid var(--color-purple);
        box-shadow: var(--shadow-md);
      }

      .widget-panel-header {
        color: var(--color-purple);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
        margin-bottom: 20px;
      }

      .widget-panel-header h3 {
        font-weight: 800;
        font-size: 1.3rem;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .widget-description {
        margin-bottom: 20px;
        line-height: 1.6;
        color: var(--text-secondary);
        font-size: 0.95rem;
      }

      /* --- POP-UP MODAL TRUNG TÂM TUYỆT ĐỐI (CENTRAL DIALOG SYSTEM) --- */
      .modal-super-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(15, 23, 42, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 99999;
        opacity: 0;
        pointer-events: none;
