        function toggleAuth() {
            if (!isLoggedIn) {
                let pwd = prompt("Nhập mật khẩu quản trị viên:");
                if (pwd === currentAdminPassword || (currentAdminPassword === "admin" && pwd === "00")) { 
                    isLoggedIn = true; 
                } else { 
                    alert("Mật khẩu nhập vào không chính xác!"); 
                }
            } else { 
                isLoggedIn = false; 
                cancelMemberForm(); 
            }
            updateAuthUI();
            renderAttendanceTable();
            renderMembersTable();
        }

        function updateAuthUI() {
            const text = document.getElementById('roleText');
            const btn = document.getElementById('authBtn');
            const thActions = document.getElementById('thActions');
            const memberForm = document.getElementById('memberFormContainer');
            
            document.getElementById('changeBgBtn').classList.toggle('hidden', !isLoggedIn);
            document.getElementById('btnSaveMinutes').classList.toggle('hidden', !isLoggedIn);
            document.getElementById('changePwdBtn').classList.toggle('hidden', !isLoggedIn);
            document.getElementById('btnDeleteHistory').classList.toggle('hidden', !isLoggedIn);
            document.getElementById('btnDeleteAllHistory').classList.toggle('hidden', !isLoggedIn); // Ẩn/Hiện nút xóa hết
            
            if(isLoggedIn) {
                text.innerText = "Quản trị viên";
                btn.innerHTML = "<i class='fa-solid fa-right-from-bracket'></i> Đăng xuất";
                document.getElementById('meetingMinutes').removeAttribute('disabled');
                thActions.classList.remove('hidden');
                memberForm.classList.remove('hidden');
                if(originalMembers.length === 0) document.getElementById('btnInitData').classList.remove('hidden');
            } else {
                text.innerText = "Khách Xem";
                btn.innerHTML = "<i class='fa-solid fa-right-to-bracket'></i> Đăng nhập";
                document.getElementById('meetingMinutes').setAttribute('disabled', 'true');
                thActions.classList.add('hidden');
                memberForm.classList.add('hidden');
                document.getElementById('btnInitData').classList.add('hidden');
            }
        }

        function switchTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.getElementById('content-' + tabName).classList.remove('hidden');
            document.querySelectorAll('.tab-btn').forEach(b => b.className = "tab-btn flex-1 min-w-[120px] py-2.5 rounded-lg text-sm font-bold transition flex items-center justify-center gap-2 text-slate-400 hover:bg-slate-800 hover:text-slate-200");
            document.getElementById('tab-' + tabName).className = "tab-btn flex-1 min-w-[120px] py-2.5 rounded-lg text-sm font-bold transition flex items-center justify-center gap-2 bg-blue-600 text-white";
        }

        function exportAllFirebaseToExcel() {
            let sortedDates = Object.keys(attendanceDataGlobal).sort();
            let headerRow = ["STT", "HỌ VÀ TÊN", "Năm sinh", "Tổng số buổi", "Vắng (K)", "Phép (P)"];
            sortedDates.forEach(d => {
                if (attendanceDataGlobal[d] && Object.keys(attendanceDataGlobal[d]).length > 0) {
                    headerRow.push(d);
                }
            }); 

            let excelRows = [
                ["DANH SÁCH ĐOÀN VIÊN XÃ ĐỨC QUANG"],
                ["Chi đoàn thôn Tiến Hòa"],
                [],
                headerRow
            ];

            originalMembers.forEach((m, idx) => {
                let stats = getMemberStats(m.id);
                let rowData = [idx + 1, m.name, m.birthYear, stats.total, stats.k, stats.p];
                
                sortedDates.forEach(date => {
                    if (attendanceDataGlobal[date] && Object.keys(attendanceDataGlobal[date]).length > 0) {
                        let status = attendanceDataGlobal[date][m.id] || "X";
                        rowData.push(status);
                    }
                });
                excelRows.push(rowData);
            });

            const ws = XLSX.utils.aoa_to_sheet(excelRows);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "Chi Đoàn Tiến Hòa");
            XLSX.writeFile(wb, `Danhsachdoanvientienhoa_Firebase.xlsx`);
        }
    </script>
